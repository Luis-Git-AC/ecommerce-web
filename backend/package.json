{
  "name": "backend",
  "version": "1.0.0",
  "description": "Ecommerce backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:products": "tsx scripts/seed-products.ts",
    "seed:content": "tsx scripts/seed-content.ts",
    "seed:all": "npm run seed:products && npm run seed:content",
    "smoke:products": "tsx scripts/smoke-products.ts",
    "smoke:content": "tsx scripts/smoke-content.ts",
    "smoke:all": "npm run smoke:products && npm run smoke:content",
    "seed:and:smoke": "npm run seed:products && npm run smoke:products",
    "assets:inventory:ia": "tsx scripts/inventory-ia-assets.ts",
    "assets:upload:ia": "tsx scripts/upload-ia-to-cloudinary.ts",
    "assets:cloudinary:ia": "npm run assets:inventory:ia && npm run assets:upload:ia"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.3.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  }
}
